    "background",
    "scanner",
    "beacon",
    "device",
    "python",
    "typescript",
    "windows-lock"
  ],
  "homepage": "https://github.com/Forgata/forgy#readme",
  "bugs": {
    "url": "https://github.com/Forgata/forgy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forgata/forgy.git"
  },
  "license": "MIT",
  "author": "Forgata",
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/main.js",
